<section class="page-header">
  <h2 class="page-title">Productos</h2>
  <p class="page-sub">{{pagination.totalDocs}} productos disponibles — Página {{pagination.page}} de {{pagination.totalPages}}</p>
</section>

<section class="products-grid">
  {{#each products}}
  <div class="product-card" data-id="{{this._id}}">
    <div class="product-category">{{this.category}}</div>
    <h3 class="product-name">{{this.name}}</h3>
    <p class="product-desc">{{this.description}}</p>
    <div class="product-footer">
      <span class="product-price">${{this.price}}</span>
      <span class="product-stock {{#if (gt this.stock 0)}}in-stock{{else}}no-stock{{/if}}">
        {{#if (gt this.stock 0)}}Stock: {{this.stock}}{{else}}Sin stock{{/if}}
      </span>
    </div>
    <button class="btn btn-primary btn-sm add-to-cart" data-id="{{this._id}}" data-name="{{this.name}}">
      + Agregar
    </button>
  </div>
  {{else}}
  <p class="empty-state">No hay productos disponibles.</p>
  {{/each}}
</section>

<!-- Controles de Paginación -->
<div class="pagination-container">
  <div class="pagination">
    {{#if pagination.hasPrevPage}}
      <a href="/shop?page={{pagination.prevPage}}&limit={{pagination.limit}}&sort={{pagination.sort}}&query={{pagination.query}}" class="btn btn-outline btn-sm">← Anterior</a>
    {{else}}
      <button class="btn btn-outline btn-sm" disabled>← Anterior</button>
    {{/if}}

    <span class="pagination-info">Página {{pagination.page}} de {{pagination.totalPages}}</span>

    {{#if pagination.hasNextPage}}
      <a href="/shop?page={{pagination.nextPage}}&limit={{pagination.limit}}&sort={{pagination.sort}}&query={{pagination.query}}" class="btn btn-outline btn-sm">Siguiente →</a>
    {{else}}
      <button class="btn btn-outline btn-sm" disabled>Siguiente →</button>
    {{/if}}
  </div>
</div>

<style>
  .pagination-container { display: flex; justify-content: center; margin-top: 3rem; margin-bottom: 2rem; }
  .pagination { display: flex; align-items: center; gap: 1rem; background: var(--surface); padding: 1rem; border-radius: 8px; border: 1px solid var(--border); }
  .pagination-info { font-weight: 600; font-size: 0.9rem; color: var(--text); }
</style>

<script>
document.querySelectorAll('.add-to-cart').forEach(btn => {
  btn.addEventListener('click', async () => {
    const id = btn.dataset.id;
    const name = btn.dataset.name;
    const token = localStorage.getItem('token');
    if (!token) { showToast('Debés iniciar sesión primero', 'warning'); return; }
    btn.disabled = true;
    btn.textContent = '…';
    try {
      const res = await fetch('/api/cart/add', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
        body: JSON.stringify({ productId: id, quantity: 1 })
      });
      const data = await res.json();
      if (data.success) {
        showToast(`"${name}" agregado al carrito ✓`, 'success');
        updateCartBadge(data.data.cart.items.length);
      } else {
        showToast(data.message, 'error');
      }
    } catch(e) { showToast('Error de conexión', 'error'); }
    btn.disabled = false;
    btn.textContent = '+ Agregar';
  });
});
</script>
