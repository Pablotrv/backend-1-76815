<section class="page-header">
  <h2 class="page-title">Finalizar Compra</h2>
  <p class="page-sub">Completa tu pedido en 3 pasos</p>
</section>

<div class="checkout-layout">
  <!-- Formulario de Checkout -->
  <div class="checkout-form">
    <form id="checkoutForm">
      <!-- Paso 1: Resumen del carrito -->
      <div class="checkout-section">
        <h3 class="section-title">📦 Resumen del Pedido</h3>
        <div class="order-summary" id="orderSummary">
          <p class="loading-text">Cargando carrito…</p>
        </div>
      </div>

      <!-- Paso 2: Información de envío -->
      <div class="checkout-section">
        <h3 class="section-title">🚚 Información de Envío</h3>
        <div class="form-group">
          <label for="street">Calle y Número</label>
          <input
            type="text"
            id="street"
            name="street"
            placeholder="Ej: Av. Corrientes 1234"
            required
          />
        </div>
        <div class="form-row">
          <div class="form-group">
            <label for="city">Ciudad</label>
            <input
              type="text"
              id="city"
              name="city"
              placeholder="Ej: Buenos Aires"
              required
            />
          </div>
          <div class="form-group">
            <label for="state">Provincia/Estado</label>
            <input
              type="text"
              id="state"
              name="state"
              placeholder="Ej: CABA"
              required
            />
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label for="zipCode">Código Postal</label>
            <input
              type="text"
              id="zipCode"
              name="zipCode"
              placeholder="Ej: 1043"
              required
            />
          </div>
          <div class="form-group">
            <label for="country">País</label>
            <input
              type="text"
              id="country"
              name="country"
              placeholder="Ej: Argentina"
              required
            />
          </div>
        </div>
      </div>

      <!-- Paso 3: Método de pago -->
      <div class="checkout-section">
        <h3 class="section-title">💳 Método de Pago</h3>
        <div class="payment-methods">
          <label class="payment-option">
            <input type="radio" name="paymentMethod" value="tarjeta" checked />
            <span class="payment-label">💳 Tarjeta de Crédito/Débito</span>
          </label>
          <label class="payment-option">
            <input type="radio" name="paymentMethod" value="transferencia" />
            <span class="payment-label">🏦 Transferencia Bancaria</span>
          </label>
          <label class="payment-option">
            <input type="radio" name="paymentMethod" value="efectivo" />
            <span class="payment-label">💵 Efectivo</span>
          </label>
        </div>
      </div>

      <!-- Botones de acción -->
      <div class="checkout-actions">
        <a href="/cart" class="btn btn-outline">← Volver al carrito</a>
        <button type="submit" class="btn btn-success btn-large" id="submitBtn">✓
          Confirmar Pedido</button>
      </div>
    </form>
  </div>

  <!-- Resumen lateral -->
  <div class="checkout-sidebar">
    <div class="sidebar-card">
      <h4>Total del Pedido</h4>
      <div class="total-display" id="totalDisplay">$0.00</div>
      <div class="sidebar-info">
        <div class="info-row"><span>Subtotal</span><span
            id="subtotalDisplay"
          >$0.00</span></div>
        <div class="info-row"><span>Envío</span><span>Gratis</span></div>
        <div class="info-divider"></div>
        <div class="info-row total"><span>TOTAL</span><span
            id="totalFinalDisplay"
          >$0.00</span></div>
      </div>
    </div>
    <div class="sidebar-card">
      <h4>Items en el Pedido</h4>
      <div id="itemsSummary"></div>
    </div>
  </div>
</div>

<style>
  .checkout-layout {
    display: grid;
    grid-template-columns: 1fr 350px;
    gap: 2rem;
    margin: 2rem 0;
  }

  .checkout-form {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 2rem;
  }

  .checkout-section {
    margin-bottom: 2rem;
  }

  .checkout-section:last-of-type {
    margin-bottom: 0;
  }

  .section-title {
    font-size: 1.1rem;
    font-weight: 600;
    margin-bottom: 1rem;
    color: var(--text);
  }

  .order-summary {
    background: var(--bg);
    border-radius: 6px;
    padding: 1rem;
    margin-bottom: 1rem;
  }

  .order-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--border);
  }

  .order-item:last-child {
    border-bottom: none;
  }

  .order-item-name {
    flex: 1;
    font-weight: 500;
  }

  .order-item-detail {
    color: var(--text-muted);
    font-size: 0.9rem;
    margin: 0.25rem 0 0 0;
  }

  .order-item-price {
    font-weight: 600;
    color: var(--accent);
    margin-left: 1rem;
  }

  .form-group {
    margin-bottom: 1rem;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .form-group label {
    display: block;
    font-weight: 500;
    margin-bottom: 0.5rem;
    color: var(--text);
  }

  .form-group input,
  .form-group select {
    width: 100%;
    padding: 0.75rem;
    border: 1px solid var(--border);
    border-radius: 4px;
    font-family: inherit;
    font-size: 1rem;
    background: var(--bg);
    color: var(--text);
    transition: border-color 0.2s;
  }

  .form-group input:focus,
  .form-group select:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent) 22;
  }

  .payment-methods {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .payment-option {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem;
    border: 2px solid var(--border);
    border-radius: 6px;
    cursor: pointer;
    transition: all 0.2s;
  }

  .payment-option:hover {
    border-color: var(--accent);
    background: var(--bg);
  }

  .payment-option input[type="radio"] {
    cursor: pointer;
    width: 20px;
    height: 20px;
  }

  .payment-option input[type="radio"]:checked + .payment-label {
    color: var(--accent);
    font-weight: 600;
  }

  .payment-label {
    flex: 1;
    font-size: 1rem;
  }

  .checkout-actions {
    display: flex;
    gap: 1rem;
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  .btn-large {
    flex: 1;
    padding: 1rem;
    font-size: 1.05rem;
    font-weight: 600;
  }

  .checkout-sidebar {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .sidebar-card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.5rem;
    position: sticky;
    top: 2rem;
  }

  .sidebar-card h4 {
    margin-bottom: 1rem;
    color: var(--text);
    font-size: 1rem;
  }

  .total-display {
    font-size: 2rem;
    font-weight: 700;
    color: var(--success);
    margin-bottom: 1rem;
  }

  .sidebar-info {
    font-size: 0.95rem;
  }

  .info-row {
    display: flex;
    justify-content: space-between;
    margin-bottom: 0.5rem;
    color: var(--text-muted);
  }

  .info-row.total {
    color: var(--text);
    font-weight: 600;
    font-size: 1.1rem;
    margin-top: 0.75rem;
  }

  .info-divider {
    height: 1px;
    background: var(--border);
    margin: 0.75rem 0;
  }

  .item-summary {
    background: var(--bg);
    border-radius: 4px;
    padding: 0.75rem;
    margin-bottom: 0.5rem;
    display: flex;
    justify-content: space-between;
    font-size: 0.9rem;
  }

  .item-summary-name {
    font-weight: 500;
  }

  .item-summary-qty {
    color: var(--text-muted);
    margin: 0 0.5rem;
  }

  @media (max-width: 768px) {
    .checkout-layout {
      grid-template-columns: 1fr;
    }

    .sidebar-card {
      position: static;
    }

    .form-row {
      grid-template-columns: 1fr;
    }

    .checkout-actions {
      flex-direction: column;
    }
  }
</style>

<script>
  const token = localStorage.getItem('token'); // Cargar resumen del carrito
  async function loadCheckoutCart() { if (!token) {
  document.getElementById('checkoutForm').innerHTML = '<p class="empty-state">⚠️
  Debés <a href="/auth/login">iniciar sesión</a> primero.</p>'; return; } try {
  const res = await fetch('/api/cart', { headers: { 'Authorization': 'Bearer ' +
  token } }); const data = await res.json(); if (!data.success ||
  !data.data.cart.items || data.data.cart.items.length === 0) {
  document.getElementById('checkoutForm').innerHTML = '<p class="empty-state">Tu
  carrito está vacío. <a href="/shop">Ver productos →</a></p>'; return; }
  renderCheckoutSummary(data.data.cart); } catch (e) { showToast('Error al
  cargar el carrito', 'error'); } } function renderCheckoutSummary(cart) { //
  Resumen del pedido const summaryHTML = cart.items.map(item => ` <div
  class="order-item"> <div style="flex: 1;"> <div
  class="order-item-name">${item.product.name}</div> <div
  class="order-item-detail">Cantidad: ${item.quantity}</div> </div> <div
  class="order-item-price">$${(item.price * item.quantity).toFixed(2)}</div>
  </div> `).join(''); document.getElementById('orderSummary').innerHTML =
  summaryHTML; // Resumen en el sidebar const itemsHTML = cart.items.map(item =>
  ` <div class="item-summary"> <span
  class="item-summary-name">${item.product.name}</span> <span
  class="item-summary-qty">×${item.quantity}</span> <span>$${(item.price *
  item.quantity).toFixed(2)}</span> </div> `).join('');
  document.getElementById('itemsSummary').innerHTML = itemsHTML; // Totales
  document.getElementById('subtotalDisplay').textContent = '$' +
  cart.total.toFixed(2); document.getElementById('totalDisplay').textContent =
  '$' + cart.total.toFixed(2);
  document.getElementById('totalFinalDisplay').textContent = '$' +
  cart.total.toFixed(2); // Llenar datos iniciales
  document.getElementById('street').value = 'Av. Corrientes 1234';
  document.getElementById('city').value = 'Buenos Aires';
  document.getElementById('state').value = 'CABA';
  document.getElementById('zipCode').value = '1043';
  document.getElementById('country').value = 'Argentina'; } // Manejar envío del
  formulario document.getElementById('checkoutForm').addEventListener('submit',
  async (e) => { e.preventDefault(); if (!token) { showToast('Sesión expirada.
  Iniciá sesión de nuevo.', 'warning'); return; } const submitBtn =
  document.getElementById('submitBtn'); submitBtn.disabled = true;
  submitBtn.textContent = '⏳ Procesando…'; try { const shippingAddress = {
  street: document.getElementById('street').value, city:
  document.getElementById('city').value, state:
  document.getElementById('state').value, zipCode:
  document.getElementById('zipCode').value, country:
  document.getElementById('country').value, }; const paymentMethod =
  document.querySelector('input[name="paymentMethod"]:checked').value; const res
  = await fetch('/api/orders/checkout', { method: 'POST', headers: {
  'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token, },
  body: JSON.stringify({ shippingAddress, paymentMethod }), }); const data =
  await res.json(); if (data.success) { showToast('🎉 ¡Pedido creado
  exitosamente!', 'success'); setTimeout(() => { window.location.href = '/cart';
  }, 2000); } else { showToast(data.message || 'Error al crear el pedido',
  'error'); submitBtn.disabled = false; submitBtn.textContent = '✓ Confirmar
  Pedido'; } } catch (e) { showToast('Error de conexión: ' + e.message,
  'error'); submitBtn.disabled = false; submitBtn.textContent = '✓ Confirmar
  Pedido'; } }); loadCheckoutCart();
</script>